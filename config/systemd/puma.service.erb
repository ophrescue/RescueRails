[Unit]
Description = <%= fetch(:application) %> puma rack server

[Service]
Environment = PATH=<%= fetch(:direct_rbenv_path) %>/shims:/usr/local/bin:/usr/bin:/bin
Environment = RBENV_VERSION=<%= fetch(:rbenv_ruby) %>
Environment = RBENV_ROOT=<%= fetch(:direct_rbenv_path) %>
Environment = RAILS_ENV=<%= fetch(:rails_env) %>
Environment = PWD=<%= current_path %>

WorkingDirectory = <%= current_path %>

ExecStart = <%= fetch(:direct_rbenv_path) %>/bin/rbenv exec bundle exec puma -C <%= current_path %>/config/puma.rb
ExecReload = /bin/kill -USR2 $MAINPID

PIDFile = <%= shared_path %>/tmp/pids/puma.pid
KillSignal = SIGTERM
KillMode = process
TimeoutStopSec = 40
Restart = always

User = deploy
Group = deploy

[Install]
WantedBy = default.target
